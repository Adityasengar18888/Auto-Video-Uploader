# ===========================
# Auto-Uploader Configuration
# ===========================
# Copy this file to .env and fill in your values

# --- Instagram Credentials ---
INSTAGRAM_USERNAME=raju.mistry.official
INSTAGRAM_PASSWORD=aditya@18

# --- Video Settings ---
# Path to the folder containing your videos
VIDEOS_FOLDER=D:\videos

# Number of videos to upload per day (per platform)
VIDEOS_PER_DAY=39

# --- YouTube Settings ---
# Privacy status for YouTube uploads: public, unlisted, or private
YT_PRIVACY=public

# YouTube category ID (22 = People & Blogs, 24 = Entertainment, 10 = Music)
# Full list: https://developers.google.com/youtube/v3/docs/videoCategories/list
YT_CATEGORY_ID=22

# Default YouTube video description (used if no custom description provided)
YT_DEFAULT_DESCRIPTION=

# Default YouTube tags (comma-separated)
YT_DEFAULT_TAGS=

# --- Schedule Settings ---
# Time to run daily uploads (24-hour format, e.g., 09:00)
UPLOAD_TIME=09:00

# Delay range between uploads in seconds (min,max) — for safety/rate limiting
UPLOAD_DELAY_MIN=30
UPLOAD_DELAY_MAX=120
